{
    "tasks": {
        "dev": "deno run --allow-all --watch --unstable-kv index.ts",
        "start": "deno run --allow-all index.ts"
    },
    "imports": {
        "@db/postgres": "jsr:@db/postgres@^0.19.5",
        "@felix/bcrypt": "jsr:@felix/bcrypt@^1.0.8",
        "@juannpz/deno-service-tools": "jsr:@juannpz/deno-service-tools@0.6.0",
        "@juannpz/extra-sql": "jsr:@juannpz/extra-sql@0.1.3",
        "@std/dotenv": "jsr:@std/dotenv@^0.225.5"
    },
    "lint": {
        "rules": {
            "tags": ["recommended"]
        }
    },
    "fmt": {
        "useTabs": false,
        "indentWidth": 4,
        "lineWidth": 100
    }
}
